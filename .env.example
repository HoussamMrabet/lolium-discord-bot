# ============================================================================
#  discord-lol-bot — environment configuration
#  Copy this file to `.env` and fill in the values. NEVER commit `.env`.
#  Keep THIS file (.env.example) with placeholder values only — no real secrets.
#  Validation happens at boot (src/config/env.js). Missing/invalid required
#  values cause the process to fail fast and exit(1).
# ============================================================================

# --- Runtime -----------------------------------------------------------------
# development | test | production
NODE_ENV=development
# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info
# Logical name attached to every log line.
SERVICE_NAME=discord-lol-bot
# mono | bot | scheduler | worker | api
# `mono` runs everything in one process (cheap, single-server deployments).
RUN_MODE=mono

# --- Discord -----------------------------------------------------------------
# Bot token from https://discord.com/developers/applications -> Bot
DISCORD_TOKEN=
# Application (client) ID — used for slash-command registration.
DISCORD_CLIENT_ID=
# OAuth2 client secret — only required by the REST API / dashboard.
DISCORD_CLIENT_SECRET=
# OAuth2 redirect URI registered in the Discord developer portal.
DISCORD_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/discord/callback
# Optional: register commands to a single guild instantly during development.
DISCORD_DEV_GUILD_ID=
# Optional: 'auto' lets Discord decide the shard count, or set an integer.
SHARD_COUNT=auto

# --- Riot Games API ----------------------------------------------------------
# Key from https://developer.riotgames.com/ (dev key or production key).
RIOT_API_KEY=
# Max retry attempts for transient Riot failures (5xx / network).
RIOT_MAX_RETRIES=3

# --- MongoDB -----------------------------------------------------------------
MONGO_URI=mongodb://127.0.0.1:27017/discord_lol_bot
# Optional explicit database name (otherwise taken from the URI).
MONGO_DB_NAME=

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379

# --- REST API / Dashboard ----------------------------------------------------
API_PORT=3000
API_BASE_URL=http://localhost:3000
# Web dashboard origin (enables credentialed CORS + post-login redirect). Optional.
DASHBOARD_URL=
# Secret used to sign session cookies. Use a long random string (32+ chars).
SESSION_SECRET=change-me-to-a-long-random-string
# Set to true when serving over HTTPS (marks cookies Secure).
COOKIE_SECURE=false

# --- Workers -----------------------------------------------------------------
# Which queue a `worker` process consumes (ignored in mono mode, which runs all).
# riot-fetch | match-process | notify-dispatch | leaderboard-compute | role-sync | recap-generate | all
WORKER_TYPE=all
WORKER_CONCURRENCY=5

# --- Scheduler ---------------------------------------------------------------
# How often (ms) the scheduler scans the poll due-set.
POLL_TICK_INTERVAL_MS=10000
